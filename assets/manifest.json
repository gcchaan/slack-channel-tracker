{
  "display_information": {
    "name": "slack-channel-tracker"
  },
  "features": {
    "bot_user": {
      "display_name": "slack-channel-tracker",
      "always_online": false
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": ["channels:read", "chat:write"]
    },
    "pkce_enabled": false
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://example.com",
      "bot_events": [
        "channel_archive",
        "channel_created",
        "channel_deleted",
        "channel_unarchive"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false,
    "is_mcp_enabled": false
  }
}
